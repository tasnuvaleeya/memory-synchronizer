{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentsync.dev/schemas/v1/frontmatter.json",
  "title": "Agentsync Memory File Frontmatter",
  "description": "YAML frontmatter block at the top of a memory markdown file.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "minLength": 1,
      "maxLength": 64
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "source": {
      "type": "string",
      "enum": ["authored", "generated", "hybrid"],
      "default": "authored"
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "default": 50
    },
    "applies_to": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["*", "claude", "agents-md", "cursor", "cline", "windsurf", "copilot"]
      },
      "default": ["*"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
