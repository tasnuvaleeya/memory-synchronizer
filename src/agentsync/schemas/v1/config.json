{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentsync.dev/schemas/v1/config.json",
  "title": "Agentsync Local Config",
  "description": "Per-repo settings stored at .agentsync/config.yaml.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "agent_dir": {
      "type": "string",
      "default": "agent",
      "description": "Directory (relative to repo root) holding the canonical memory files."
    },
    "default_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["claude", "agents-md", "cursor", "cline", "windsurf", "copilot"]
      },
      "uniqueItems": true,
      "default": []
    },
    "telemetry": {
      "type": "boolean",
      "default": false
    }
  }
}
