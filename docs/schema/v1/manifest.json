{
  "$ref": "#/definitions/Manifest",
  "definitions": {
    "Manifest": {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1
        },
        "project": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "source": {
                "type": "string",
                "enum": [
                  "authored",
                  "generated",
                  "hybrid"
                ]
              },
              "priority": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100,
                "default": 50
              },
              "applies_to": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "default": [
                  "*"
                ]
              }
            },
            "required": [
              "path",
              "source"
            ],
            "additionalProperties": false
          }
        },
        "generation": {
          "type": "object",
          "properties": {
            "scanner": {
              "type": "string",
              "enum": [
                "web-tree-sitter",
                "shape",
                "off"
              ],
              "default": "shape"
            },
            "exclude": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {
            "scanner": "shape",
            "exclude": []
          }
        }
      },
      "required": [
        "version",
        "project",
        "targets",
        "files"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
