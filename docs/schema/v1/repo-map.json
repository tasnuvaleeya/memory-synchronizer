{
  "$ref": "#/definitions/RepoMap",
  "definitions": {
    "RepoMap": {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1
        },
        "summary": {
          "type": "object",
          "properties": {
            "totalFiles": {
              "type": "integer",
              "minimum": 0
            },
            "totalLines": {
              "type": "integer",
              "minimum": 0
            },
            "languages": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "language": {
                    "type": "string"
                  },
                  "files": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "lines": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "required": [
                  "language",
                  "files",
                  "lines"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "totalFiles",
            "totalLines",
            "languages"
          ],
          "additionalProperties": false
        },
        "tree": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "dir",
                "file"
              ]
            },
            "children": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/RepoMap/properties/tree"
              }
            },
            "lineCount": {
              "type": "integer",
              "minimum": 0
            },
            "language": {
              "type": [
                "string",
                "null"
              ]
            },
            "role": {
              "type": "string",
              "enum": [
                "entry",
                "test",
                "config",
                "doc",
                "source"
              ]
            }
          },
          "required": [
            "name",
            "path",
            "type"
          ],
          "additionalProperties": false
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "role": {
                "$ref": "#/definitions/RepoMap/properties/tree/properties/role"
              },
              "language": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "lineCount": {
                "type": "integer",
                "minimum": 0
              },
              "sha": {
                "type": "string",
                "minLength": 64,
                "maxLength": 64
              }
            },
            "required": [
              "path",
              "role",
              "language",
              "lineCount",
              "sha"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "version",
        "summary",
        "tree",
        "files"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
