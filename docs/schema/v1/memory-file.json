{
  "$ref": "#/definitions/MemoryFile",
  "definitions": {
    "MemoryFile": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "frontmatter": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "source": {
              "type": "string",
              "enum": [
                "authored",
                "generated",
                "hybrid"
              ],
              "default": "authored"
            },
            "priority": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "default": 50
            },
            "applies_to": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": [
                "*"
              ]
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": []
            }
          },
          "required": [
            "name",
            "description"
          ],
          "additionalProperties": false
        },
        "body": {
          "type": "string"
        },
        "sha": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        }
      },
      "required": [
        "path",
        "frontmatter",
        "body",
        "sha"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
